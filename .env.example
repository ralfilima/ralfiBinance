# ============================================
# BINANCE BOT - CONFIGURAÇÃO DE AMBIENTE
# ============================================
# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA compartilhe ou commite o arquivo .env!

# --- Binance API (Conta Real / Mainnet) ---
BINANCE_API_KEY=sua_api_key_real_aqui
BINANCE_API_SECRET=sua_api_secret_real_aqui

# --- Binance API (Testnet) ---
BINANCE_TESTNET_API_KEY=sua_api_key_testnet_aqui
BINANCE_TESTNET_API_SECRET=sua_api_secret_testnet_aqui

# --- Telegram ---
TELEGRAM_BOT_TOKEN=seu_token_telegram_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# --- Modo de Operação ---
# USE_TESTNET=true para testnet, false para conta real
USE_TESTNET=true
