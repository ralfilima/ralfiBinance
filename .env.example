# Copie este arquivo para .env e preencha:
#   cp .env.example .env

# --- Binance Testnet ---
BINANCE_TESTNET_API_KEY=sua_testnet_api_key
BINANCE_TESTNET_API_SECRET=sua_testnet_api_secret

# --- Binance Conta Real ---
BINANCE_API_KEY=sua_api_key_real
BINANCE_API_SECRET=sua_api_secret_real

# --- Telegram (opcional) ---
TELEGRAM_BOT_TOKEN=seu_bot_token
TELEGRAM_CHAT_ID=seu_chat_id
